# ── DATABASE ──────────────────────────────────────────────────────────────────
# asyncpg driver required for SQLAlchemy async sessions
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ai_notes_hub

# ── SECURITY ──────────────────────────────────────────────────────────────────
# Must be at least 32 bytes. Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-super-secret-key-minimum-32-bytes-long

# ── GOOGLE OAUTH 2.0 ──────────────────────────────────────────────────────────
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI must include: <BACKEND_URL>/auth/google/callback
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── GOOGLE GEMINI AI ──────────────────────────────────────────────────────────
# Get your key at https://aistudio.google.com/apikey
# Used for: summarization, auto-tagging, embeddings (768-dim), RAG Q&A
GEMINI_API_KEY=your-gemini-api-key

# ── CLOUDINARY (file attachments) ─────────────────────────────────────────────
# Find these at https://console.cloudinary.com → Settings → API Keys
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# ── CORS ──────────────────────────────────────────────────────────────────────
# Frontend origin — must match exactly (no trailing slash)
FRONTEND_URL=http://localhost:5173

# ── SENTRY (optional) ─────────────────────────────────────────────────────────
# Leave empty to disable Sentry in local development
SENTRY_DSN=

# ── ENVIRONMENT ───────────────────────────────────────────────────────────────
# Controls Sentry environment tag: "development" | "production"
APP_ENV=development

# ── TESTING (optional) ────────────────────────────────────────────────────────
# Separate DB for pytest — avoids polluting dev data
# TEST_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ai_notes_hub_test
